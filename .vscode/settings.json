{
  "editor.formatOnSave": true,
  "files.exclude": { 
    "**/.turbo": true, 
    "**/dist": true, 
    "**/.next": true,
    "**/node_modules": true
  },
  "typescript.tsdk": "node_modules/typescript/lib",
  "python.defaultInterpreterPath": "python3",
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit"
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/dist": true,
    "**/.next": true,
    "**/.turbo": true
  }
}
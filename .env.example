# QUILL Studio Environment Variables

# Server Configuration
NODE_ENV=development
API_PORT=8787
WEB_PORT=3000

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# YouTube Integration
YOUTUBE_CLIENT_ID=your-client-id
YOUTUBE_CLIENT_SECRET=your-client-secret
YOUTUBE_REDIRECT_URI=http://localhost:8787/auth/youtube/callback
YOUTUBE_API_KEY=your-api-key

# Google Ads
GOOGLE_ADS_DEVELOPER_TOKEN=your-developer-token
GOOGLE_ADS_CLIENT_ID=your-client-id
GOOGLE_ADS_CLIENT_SECRET=your-client-secret
GOOGLE_ADS_REFRESH_TOKEN=your-refresh-token

# JustCall Webhook
JUSTCALL_WEBHOOK_SECRET=your-webhook-secret
JUSTCALL_HMAC_SECRET=your-hmac-secret

# Copper CRM
COPPER_API_KEY=your-api-key
COPPER_USER_EMAIL=your-email@example.com

# Security
AUDIT_LOG_DIR=./audit-logs
HMAC_SIGNING_KEY=your-secret-key
JWT_SECRET=your-jwt-secret

# Storage Paths
VIDEO_OUTPUT_PATH=./output/videos
ASSETS_PATH=./output/assets

# FFmpeg
FFMPEG_THREADS=4
FFMPEG_PRESET=medium

# Logging
LOG_LEVEL=info
